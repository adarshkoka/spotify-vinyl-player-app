<?xml version="1.0" encoding="utf-8"?>
<!-- Tonearm in the "lifted/parked" position. Same pivot, arm angled away
     from the disc towards the rest cradle on the right. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="100dp"
    android:height="100dp"
    android:viewportWidth="100"
    android:viewportHeight="100">

    <!-- Pivot base -->
    <path
        android:pathData="M 84,16 m -8,0 a 8,8 0 1,0 16,0 a 8,8 0 1,0 -16,0"
        android:fillColor="#3A3A40" />
    <path
        android:pathData="M 84,16 m -3,0 a 3,3 0 1,0 6,0 a 3,3 0 1,0 -6,0"
        android:fillColor="#1A1A1F" />

    <!-- Arm body (parked: nearly vertical, slight angle) -->
    <path
        android:pathData="M 82,16 L 86,16 L 90,76 L 86,76 Z"
        android:fillColor="#C8C8CC" />

    <!-- Cartridge head, raised -->
    <path
        android:pathData="M 84,72 L 92,72 L 92,84 L 84,84 Z"
        android:fillColor="#1F1F23" />
</vector>
